#!/bin/bash
# thinklight on|off [--force]|status|blink [seconds]|check
# Use the Mac camera LEDs as silent, glanceable "AI agent is working" indicators.
#
# Multi-session refcounting, self-healing by design: each session's `on` drops
# a token containing its owner PID and assigned camera backend. With a Studio
# Display attached, new sessions take the less-used light (built-in wins ties);
# without one, every session shares the built-in light. `off` only extinguishes
# a backend when its last assigned session leaves.
# Tokens are hints, never trusted state — on/off sweep any token whose
# recorded process has exited, so a crashed session cannot leave the LED stuck
# on. The daemon process itself (matched with pgrep -fx on its full path —
# exact, so an editor or pager open on that path is never mistaken for it)
# remains the single source of truth for the LED.
DAEMON="$HOME/.local/bin/thinklight-daemon"
STATE="$HOME/.local/state/thinklight"
SESSIONS="$STATE/sessions"
STATE_LOCK="$STATE/state.lock"
SOURCE_FILE="$STATE/source"
REVISION_FILE="$STATE/revision"
UPDATE_CHECK_FILE="$STATE/update-check"
REPO_URL="https://github.com/lichengzhe/thinklight.git"
mkdir -p "$SESSIONS"

STATE_LOCK_HELD=0

cleanup() {
  if [[ "$STATE_LOCK_HELD" == 1 && "$(cat "$STATE_LOCK" 2>/dev/null)" == "$$" ]]; then
    rm -f "$STATE_LOCK"
  fi
}
trap cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

acquire_state_lock() {
  local tries=0
  while ! /usr/bin/shlock -f "$STATE_LOCK" -p $$; do
    tries=$((tries + 1))
    [[ "$tries" -lt 100 ]] || return 1
    sleep 0.02
  done
  STATE_LOCK_HELD=1
}

release_state_lock() {
  if [[ "$STATE_LOCK_HELD" == 1 && "$(cat "$STATE_LOCK" 2>/dev/null)" == "$$" ]]; then
    rm -f "$STATE_LOCK"
  fi
  STATE_LOCK_HELD=0
}

lock_or_die() {
  acquire_state_lock && return 0
  echo "thinklight: timed out waiting for state lock" >&2
  exit 75
}

# Hooks pipe a JSON payload on stdin; its session_id names the token so this
# session's on and off pair up even across apps with different environments.
# Manual runs (or payloads without one) fall back to the owning process's PID.
KEY=""
[[ -t 0 ]] || KEY=$(sed -n 's/.*"session_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1)

# A bare hook command is normally exec'd directly, making PPID the long-lived
# Claude/Codex process. If a shell or launcher remains in between, walk upward
# and bind the token to the first agent host instead of that short-lived wrapper.
owner_pid() {
  local pid=$PPID parent command steps=0
  while [[ "$pid" =~ ^[0-9]+$ && "$pid" -gt 1 && "$steps" -lt 12 ]]; do
    command=$(ps -o comm= -p "$pid" 2>/dev/null)
    case "${command##*/}" in
      claude|codex) echo "$pid"; return 0 ;;
    esac
    parent=$(ps -o ppid= -p "$pid" 2>/dev/null)
    parent=${parent//[[:space:]]/}
    [[ "$parent" =~ ^[0-9]+$ ]] || break
    pid=$parent
    steps=$((steps + 1))
  done
  echo "$PPID"
}

OWNER_PID=$(owner_pid)
[[ "$KEY" =~ ^[A-Za-z0-9._-]+$ && "$KEY" != "." && "$KEY" != ".." ]] || KEY="ppid-$OWNER_PID"

sweep() {
  local f pid backend
  for f in "$SESSIONS"/*; do
    [[ -e "$f" ]] || continue
    read -r pid backend < "$f"
    [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null || rm -f "$f"
  done
}

token_backend() {
  local pid backend
  read -r pid backend < "$1"
  echo "${backend:-built-in}"
}

backend_session_count() {
  local wanted=$1 f backend count=0
  for f in "$SESSIONS"/*; do
    [[ -e "$f" ]] || continue
    backend=$(token_backend "$f")
    [[ "$backend" == "$wanted" ]] && count=$((count + 1))
  done
  echo "$count"
}

has_backend_sessions() {
  [[ "$(backend_session_count "$1")" -gt 0 ]]
}

choose_backend() {
  local built_in_count studio_count
  if ! "$DAEMON" has-studio >/dev/null 2>&1; then
    echo built-in
    return 0
  fi
  built_in_count=$(backend_session_count built-in)
  studio_count=$(backend_session_count studio)
  if [[ "$built_in_count" -le "$studio_count" ]]; then
    echo built-in
  else
    echo studio
  fi
}

daemon_running() {
  pgrep -qfx "$DAEMON" \
    || pgrep -qfx "$DAEMON both" \
    || pgrep -qfx "$DAEMON built-in" \
    || pgrep -qfx "$DAEMON studio"
}

start_backend() {
  local backend=$1 pid tries=0
  pgrep -qfx "$DAEMON $backend" && return 0
  nohup "$DAEMON" "$backend" >/dev/null 2>&1 &
  pid=$!
  while kill -0 "$pid" 2>/dev/null; do
    pgrep -qfx "$DAEMON $backend" && return 0
    tries=$((tries + 1))
    [[ "$tries" -lt 20 ]] || break
    sleep 0.05
  done
  return 1
}

stop_backend() {
  local backend=$1 tries=0
  pkill -fx "$DAEMON $backend" 2>/dev/null || return 0
  while pgrep -qfx "$DAEMON $backend"; do
    tries=$((tries + 1))
    [[ "$tries" -lt 20 ]] || break
    sleep 0.05
  done
}

stop_legacy_daemons() {
  local tries=0
  pkill -fx "$DAEMON" 2>/dev/null || true
  pkill -fx "$DAEMON both" 2>/dev/null || true
  while pgrep -qfx "$DAEMON" || pgrep -qfx "$DAEMON both"; do
    tries=$((tries + 1))
    [[ "$tries" -lt 20 ]] || break
    sleep 0.05
  done
}

reconcile_daemons() {
  local backend f pid assigned
  stop_legacy_daemons
  if ! "$DAEMON" has-studio >/dev/null 2>&1; then
    for f in "$SESSIONS"/*; do
      [[ -e "$f" ]] || continue
      read -r pid assigned < "$f"
      [[ "${assigned:-built-in}" == studio ]] && echo "$pid built-in" > "$f"
    done
  fi
  for backend in built-in studio; do
    if has_backend_sessions "$backend"; then
      start_backend "$backend"
    else
      stop_backend "$backend"
    fi
  done
}

remote_revision() {
  git ls-remote "$REPO_URL" refs/heads/main 2>/dev/null | awk 'NR == 1 { print $1 }'
}

check_update() {
  local installed remote
  installed=$(cat "$REVISION_FILE" 2>/dev/null)
  [[ -n "$installed" ]] || { echo "thinklight: installed revision unknown; run install.sh again" >&2; return 1; }
  remote=$(remote_revision)
  [[ -n "$remote" ]] || { echo "thinklight: could not check for updates" >&2; return 1; }
  if [[ "$installed" == "$remote" ]]; then
    echo "thinklight: up to date (${installed:0:7})"
  else
    echo "thinklight: update available (${installed:0:7} -> ${remote:0:7}); run: thinklight update"
  fi
}

schedule_update_check() {
  local now last=0
  now=$(date +%s)
  [[ -f "$UPDATE_CHECK_FILE" ]] && last=$(cat "$UPDATE_CHECK_FILE" 2>/dev/null)
  [[ "$last" =~ ^[0-9]+$ ]] || last=0
  [[ $((now - last)) -ge 86400 ]] || return 0
  echo "$now" > "$UPDATE_CHECK_FILE"
  nohup "$0" _check_update_notify </dev/null >/dev/null 2>&1 &
}

perform_update() {
  local source branch
  source=$(cat "$SOURCE_FILE" 2>/dev/null)
  [[ -n "$source" && -d "$source/.git" && -x "$source/install.sh" ]] || {
    echo "thinklight: source checkout unavailable; clone the repo and run install.sh" >&2
    return 1
  }
  branch=$(git -C "$source" branch --show-current)
  [[ "$branch" == main ]] || { echo "thinklight: refusing to update source branch '$branch' (expected main)" >&2; return 1; }
  if ! git -C "$source" diff --quiet || ! git -C "$source" diff --cached --quiet; then
    echo "thinklight: source checkout has uncommitted changes; update manually" >&2
    return 1
  fi
  git -C "$source" pull --ff-only origin main || return 1
  "$source/install.sh"
}

case "${1:-status}" in
  on)
    local_backend=""
    lock_or_die
    sweep
    rm -f "$SESSIONS/$KEY"
    local_backend=$(choose_backend)
    echo "$OWNER_PID $local_backend" > "$SESSIONS/$KEY"
    reconcile_daemons
    schedule_update_check
    release_state_lock
    ;;
  off)
    # A human typing `off` at a terminal means "light off, now" — honor it even
    # if agent sessions are still registered. Hooks (stdin is a pipe) refcount.
    lock_or_die
    if [[ "${2:-}" == "--force" || -t 0 ]]; then
      rm -f "$SESSIONS"/*
    else
      rm -f "$SESSIONS/$KEY"
      sweep
    fi
    reconcile_daemons
    release_state_lock
    exit 0
    ;;
  blink)
    "$0" on </dev/null; sleep "${2:-2}"; "$0" off </dev/null
    ;;
  status)
    if daemon_running; then echo on; else echo off; fi
    ;;
  check)
    exec "$HOME/.local/bin/thinklight-check"
    ;;
  update)
    if [[ "${2:-}" == "--check" ]]; then check_update; else perform_update; fi
    ;;
  _check_update_notify)
    installed=$(cat "$REVISION_FILE" 2>/dev/null)
    remote=$(remote_revision)
    if [[ -n "$installed" && -n "$remote" && "$installed" != "$remote" ]]; then
      /usr/bin/osascript -e 'display notification "Run thinklight update to install it." with title "ThinkLight update available"' >/dev/null 2>&1
    fi
    ;;
  _sync)
    # Internal upgrade hook: rebuild daemon state from existing session tokens.
    lock_or_die
    sweep
    reconcile_daemons
    release_state_lock
    ;;
  *)
    echo "usage: thinklight on|off [--force]|status|blink [seconds]|check|update [--check]" >&2
    exit 64
    ;;
esac
