#!/bin/bash
# thinklight on|off [--force]|status|blink [seconds]|check|update [--check]
# One light, two states: on = an agent is running, off = nothing running.
# The daemon owns the LED; this CLI only records per-session tokens and makes
# sure the daemon is available.
BIN_DIR="${THINKLIGHT_BIN_DIR:-$HOME/.local/bin}"
DAEMON="$BIN_DIR/thinklight-daemon"
# pgrep/pkill -f patterns are regexes; escape the path so `.` and friends
# match literally wherever this ends up installed.
DAEMON_RE=$(printf '%s' "$DAEMON" | sed 's/[][*^$+?(){}|\\.]/\\&/g')
# launchd job label for this install; hashing the daemon path keeps a test CLI
# (THINKLIGHT_BIN_DIR override) away from the real install's job.
DAEMON_LABEL="thinklight-$(printf '%s' "$DAEMON" | cksum | awk '{print $1}')"
STATE="${THINKLIGHT_STATE_DIR:-$HOME/.local/state/thinklight}"
SESSIONS="$STATE/sessions"
SPAWN_LOCK="$STATE/spawn.lock"
SOURCE_FILE="$STATE/source"
REVISION_FILE="$STATE/revision"
UPDATE_CHECK_FILE="$STATE/update-check"
REPO_URL="https://github.com/lichengzhe/thinklight.git"

# Hooks pipe a JSON payload on stdin: session_id names the token so a
# session's on/off pair up even across apps with different environments.
PAYLOAD=""
KEY=""
OWNER_PID=""
SESSION_KEY=""
TRANSCRIPT_PATH=""
TURN_ID=""

json_field() {
  printf '%s' "$PAYLOAD" | sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" | head -n1
}

# A bare hook command is normally exec'd directly, making PPID the long-lived
# Claude/Codex process. If a shell or launcher remains in between, walk upward
# and bind the token to the first agent host instead of that short-lived wrapper.
owner_pid() {
  local pid=$PPID parent command steps=0
  while [[ "$pid" =~ ^[0-9]+$ && "$pid" -gt 1 && "$steps" -lt 12 ]]; do
    command=$(ps -o comm= -p "$pid" 2>/dev/null)
    case "${command##*/}" in
      claude|codex) echo "$pid"; return 0 ;;
    esac
    parent=$(ps -o ppid= -p "$pid" 2>/dev/null)
    parent=${parent//[[:space:]]/}
    [[ "$parent" =~ ^[0-9]+$ ]] || break
    pid=$parent
    steps=$((steps + 1))
  done
  echo "$PPID"
}

load_session_context() {
  mkdir -p "$SESSIONS" || {
    echo "thinklight: cannot create state directory: $SESSIONS" >&2
    return 1
  }
  PAYLOAD=""
  [[ -t 0 ]] || PAYLOAD=$(cat) || return 1
  OWNER_PID=$(owner_pid)
  SESSION_KEY=$(json_field session_id)
  [[ "$SESSION_KEY" =~ ^[A-Za-z0-9_-][A-Za-z0-9._-]*$ ]] || SESSION_KEY="ppid-$OWNER_PID"
  TRANSCRIPT_PATH=$(json_field transcript_path)
  TURN_ID=$(json_field turn_id)
  KEY="$SESSION_KEY"
  # Codex includes a stable turn id on turn-scoped hooks. Keeping each turn in
  # its own token lets the daemon reap an interrupted turn without racing the
  # next prompt from the same still-running session.
  if [[ "$TURN_ID" =~ ^[A-Za-z0-9_-][A-Za-z0-9._-]*$ ]]; then
    KEY="$SESSION_KEY.$TURN_ID"
  else
    TURN_ID=""
  fi
}

# Written via mktemp+mv so the daemon never reads a half-written token.
write_token() {
  local tmp
  tmp=$(mktemp "$SESSIONS/.tok.XXXXXX") || return 1
  if ! printf '%s\n%s\n%s\n%s\n' "$OWNER_PID" "$TRANSCRIPT_PATH" "$TURN_ID" "$SESSION_KEY" > "$tmp" \
    || ! mv -f "$tmp" "$SESSIONS/$KEY"; then
    rm -f "$tmp"
    return 1
  fi
}

remove_context_tokens() {
  local token
  if [[ -n "$TURN_ID" ]]; then
    # Also remove the legacy per-session token so upgrading while a turn is
    # active cannot strand the token written by the previous CLI version.
    rm -f "$SESSIONS/$KEY" "$SESSIONS/$SESSION_KEY"
    return
  fi
  # SessionEnd has no turn id. Remove the legacy per-session token plus any
  # turn-scoped Codex tokens that recorded this session key. Session ids may
  # contain dots, so the name prefix alone could also match a different
  # session named "$SESSION_KEY.something"; the recorded key disambiguates.
  rm -f "$SESSIONS/$SESSION_KEY" || return 1
  for token in "$SESSIONS/$SESSION_KEY".*; do
    [[ -f "$token" ]] || continue
    [[ "$(sed -n '4p' "$token" 2>/dev/null)" == "$SESSION_KEY" ]] || continue
    rm -f "$token" || return 1
  done
}

daemon_running() {
  pgrep -qfx "$DAEMON_RE"
}

any_daemon_running() {
  daemon_running \
    || pgrep -qfx "$DAEMON_RE built-in" \
    || pgrep -qfx "$DAEMON_RE studio" \
    || pgrep -qfx "$DAEMON_RE both"
}

ensure_daemon() {
  daemon_running && return 0
  [[ -x "$DAEMON" ]] || {
    echo "thinklight: daemon is not installed: $DAEMON" >&2
    return 1
  }

  # shlock reaps locks whose recorded pid is dead, so a killed CLI cannot wedge this.
  local tries=0
  while ! /usr/bin/shlock -f "$SPAWN_LOCK" -p $$; do
    tries=$((tries + 1))
    if [[ "$tries" -ge 100 ]]; then
      echo "thinklight: timed out waiting to start the daemon" >&2
      return 1
    fi
    sleep 0.02
  done

  if ! daemon_running; then
    # Spawn through launchd so the daemon is its own TCC "responsible process".
    # Spawned straight from a hook it would inherit the hosting terminal's
    # responsibility, and macOS then blames the terminal for the camera with an
    # extra green pill in the menu bar ("Ghostty is using the camera").
    launchctl remove "$DAEMON_LABEL" 2>/dev/null
    if ! launchctl submit -l "$DAEMON_LABEL" -- "$DAEMON" 2>/dev/null; then
      nohup "$DAEMON" </dev/null >/dev/null 2>&1 &
    fi
  fi
  rm -f "$SPAWN_LOCK" || return 1

  tries=0
  while ! daemon_running; do
    tries=$((tries + 1))
    if [[ "$tries" -ge 100 ]]; then
      echo "thinklight: daemon failed to start" >&2
      return 1
    fi
    sleep 0.02
  done
}

stop_daemons() {
  local tries=0
  # remove both terminates a launchd-managed daemon and drops its job label,
  # which would otherwise outlive the process; pkill covers pre-launchd daemons.
  while any_daemon_running || launchctl list "$DAEMON_LABEL" >/dev/null 2>&1; do
    launchctl remove "$DAEMON_LABEL" 2>/dev/null
    pkill -fx "$DAEMON_RE" 2>/dev/null
    # Daemon invocations from older multi-light versions took a backend argument.
    pkill -fx "$DAEMON_RE built-in" 2>/dev/null
    pkill -fx "$DAEMON_RE studio" 2>/dev/null
    pkill -fx "$DAEMON_RE both" 2>/dev/null
    tries=$((tries + 1))
    if [[ "$tries" -ge 100 ]]; then
      echo "thinklight: daemon did not stop" >&2
      return 1
    fi
    sleep 0.02
  done
}

has_sessions() {
  local token
  [[ -d "$SESSIONS" ]] || return 1
  for token in "$SESSIONS"/*; do
    [[ -f "$token" ]] && return 0
  done
  return 1
}

clear_sessions() {
  local token
  [[ -d "$SESSIONS" ]] || return 0
  for token in "$SESSIONS"/* "$SESSIONS"/.tok.*; do
    [[ -f "$token" ]] || continue
    rm -f "$token" || return 1
  done
}

remote_revision() {
  git ls-remote "$REPO_URL" refs/heads/main 2>/dev/null | awk 'NR == 1 { print $1 }'
}

check_update() {
  local installed remote
  installed=$(cat "$REVISION_FILE" 2>/dev/null)
  [[ -n "$installed" ]] || { echo "thinklight: installed revision unknown; run install.sh again" >&2; return 1; }
  remote=$(remote_revision)
  [[ -n "$remote" ]] || { echo "thinklight: could not check for updates" >&2; return 1; }
  if [[ "$installed" == "$remote" ]]; then
    echo "thinklight: up to date (${installed:0:7})"
  else
    echo "thinklight: update available (${installed:0:7} -> ${remote:0:7}); run: thinklight update"
  fi
}

schedule_update_check() {
  local now last=0
  now=$(date +%s)
  [[ -f "$UPDATE_CHECK_FILE" ]] && last=$(cat "$UPDATE_CHECK_FILE" 2>/dev/null)
  [[ "$last" =~ ^[0-9]+$ ]] || last=0
  [[ $((now - last)) -ge 86400 ]] || return 0
  echo "$now" > "$UPDATE_CHECK_FILE"
  nohup "$0" _check_update_notify </dev/null >/dev/null 2>&1 &
}

perform_update() {
  local source branch
  source=$(cat "$SOURCE_FILE" 2>/dev/null)
  [[ -n "$source" && -d "$source/.git" && -x "$source/install.sh" ]] || {
    echo "thinklight: source checkout unavailable; clone the repo and run install.sh" >&2
    return 1
  }
  branch=$(git -C "$source" branch --show-current)
  [[ "$branch" == main ]] || { echo "thinklight: refusing to update source branch '$branch' (expected main)" >&2; return 1; }
  if ! git -C "$source" diff --quiet || ! git -C "$source" diff --cached --quiet; then
    echo "thinklight: source checkout has uncommitted changes; update manually" >&2
    return 1
  fi
  git -C "$source" pull --ff-only origin main || return 1
  "$source/install.sh"
}

case "${1:-status}" in
  on)
    load_session_context || exit 1
    if ! write_token; then
      echo "thinklight: could not record the session" >&2
      exit 1
    fi
    if ! ensure_daemon; then
      rm -f "$SESSIONS/$KEY"
      exit 1
    fi
    schedule_update_check || true
    ;;
  off)
    if [[ "${2:-}" == "--force" || -t 0 ]]; then
      # A human typing `off` at a terminal means "light off, now"
      clear_sessions || exit 1
      stop_daemons || exit 1
    else
      load_session_context || exit 1
      remove_context_tokens || exit 1
    fi
    ;;
  status)
    if daemon_running && has_sessions; then echo on; else echo off; fi
    ;;
  blink)
    "$0" on </dev/null || exit 1
    sleep "${2:-2}" || exit 1
    "$0" off </dev/null
    ;;
  check)
    exec "$BIN_DIR/thinklight-check"
    ;;
  update)
    if [[ "${2:-}" == "--check" ]]; then check_update; else perform_update; fi
    ;;
  _check_update_notify)
    installed=$(cat "$REVISION_FILE" 2>/dev/null)
    remote=$(remote_revision)
    if [[ -n "$installed" && -n "$remote" && "$installed" != "$remote" ]]; then
      /usr/bin/osascript -e 'display notification "Run thinklight update to install it." with title "ThinkLight update available"' >/dev/null 2>&1
    fi
    ;;
  _sync)
    # Internal upgrade hook: replace any older daemon, then let session tokens decide.
    mkdir -p "$SESSIONS" || exit 1
    stop_daemons || exit 1
    if has_sessions; then ensure_daemon; fi
    ;;
  *)
    echo "usage: thinklight on|off [--force]|status|blink [seconds]|check|update [--check]" >&2
    exit 64
    ;;
esac
