#!/bin/bash
# thinklight on|off|status|blink [seconds]|check
# Use the Mac camera LED as an unfakeable "AI agent is working" indicator.
DAEMON="$HOME/.local/bin/thinklight-daemon"
PIDFILE="${TMPDIR:-/tmp}/thinklight.pid"

is_on() {
  [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

case "${1:-status}" in
  on)
    if is_on; then exit 0; fi
    nohup "$DAEMON" >/dev/null 2>&1 &
    echo $! > "$PIDFILE"
    ;;
  off)
    if is_on; then kill "$(cat "$PIDFILE")" 2>/dev/null; fi
    rm -f "$PIDFILE"
    ;;
  blink)
    "$0" on; sleep "${2:-2}"; "$0" off
    ;;
  status)
    if is_on; then echo on; else echo off; fi
    ;;
  check)
    exec "$HOME/.local/bin/thinklight-check"
    ;;
  *)
    echo "usage: thinklight on|off|status|blink [seconds]|check" >&2
    exit 64
    ;;
esac
