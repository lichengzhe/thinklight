{
  "description": "Camera LED status light: on while an agent is running, off when nothing is running",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/thinklight on",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/thinklight off",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
