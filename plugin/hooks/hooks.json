{
  "description": "Camera LED status light: on when a prompt is submitted, off when the turn ends or the session exits",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/thinklight on",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/thinklight off",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/thinklight off",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
